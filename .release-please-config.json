{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "google-workspace": {
      "release-type": "go",
      "component": "google-workspace",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "SKILL.md",
          "jsonpath": "$.version"
        }
      ]
    },
    "zoho-mail": {
      "release-type": "go",
      "component": "zoho-mail",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "SKILL.md",
          "jsonpath": "$.version"
        }
      ]
    },
    "aws-s3": {
      "release-type": "node",
      "component": "aws-s3",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "SKILL.md",
          "jsonpath": "$.version"
        }
      ]
    }
  },
  "initial-version": "0.1.0",
  "include-component-in-tag": true,
  "tag-separator": "/",
  "separate-pull-requests": true
}
